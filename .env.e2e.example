# E2E test credentials — copy to .env.e2e and fill in real values
# These are used by e2e/fixtures/auth.js for programmatic Supabase login

E2E_EMAIL=your-test-account@example.com
E2E_PASSWORD=your-password

# TOTP secret (base32) — required only if the test account has MFA enrolled.
# You can find it in your authenticator app settings or Supabase dashboard.
# E2E_TOTP_SECRET=JBSWY3DPEHPK3PXP
