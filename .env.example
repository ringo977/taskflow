# Copy to .env.local for local overrides (optional — defaults are baked in for dev)

# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# AI proxy (Supabase Edge Function)
# Leave empty to disable AI features in the UI
VITE_AI_PROXY_URL=https://your-project.supabase.co/functions/v1/ai-proxy
