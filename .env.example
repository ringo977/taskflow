# Copy to .env.local and fill in your Supabase project values (required)
# The app will crash at startup if these are missing.

# Supabase (required)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# AI proxy (Supabase Edge Function)
# Leave empty to disable AI features in the UI
VITE_AI_PROXY_URL=https://your-project.supabase.co/functions/v1/ai-proxy
